# ---------------------------------------------------------------------------
# Sanity CMS — copy this file to `.env.local` and fill in the values.
# The site works WITHOUT these (it falls back to the bundled content); set
# them once the centre's Sanity project exists to switch editing on.
# ---------------------------------------------------------------------------

# From sanity.io/manage → your project → API / Project ID. Safe to expose.
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Usually "production".
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version (date). Leave as-is unless you know you need a newer one.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Write token (sanity.io/manage → API → Tokens, "Editor" permission).
# SERVER ONLY — never prefix with NEXT_PUBLIC. Used only by the seed script.
SANITY_API_WRITE_TOKEN=

# Shared secret for the publish→live webhook (POST /api/revalidate). Set the
# same value here and on the Sanity webhook so published edits appear within a
# second. SERVER ONLY. Optional — without it, content still refreshes in ~60s.
SANITY_REVALIDATE_SECRET=

# One-time, browser-based content import (GET/POST /api/seed). Set this, deploy,
# open /api/seed?secret=... and click the button to populate Sanity — then
# REMOVE this var to permanently disable the import route. SERVER ONLY.
SANITY_SEED_SECRET=
